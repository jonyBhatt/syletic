generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model User {
  id         String  @id @default(uuid())
  name       String
  email      String  @unique
  password   String
  phone      String?
  role       Role    @default(BUYER)
  bio        String?
  nid        String?
  user_image String?

  created_at DateTime @default(now())

  // Relations
  properties Property[]
  favorites  Favorite[]
  inquiries  Inquiry[]
  seller     Seller?

  @@map("users")
}

model Seller {
  id           String  @id @default(uuid())
  user_id      String  @unique
  is_verified  Boolean @default(false)
  experience   Int? // years
  company_name String? // for agents
  license_no   String? // optional for agents

  created_at DateTime @default(now())

  // Relations
  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("sellers")
}

model Property {
  id          String @id @default(uuid())
  title       String
  description String
  price       Float
  currency    String
  address     String

  property_type PropertyType
  status        PropertyStatus @default(ACTIVE)

  bedrooms  Int?
  bathrooms Int?
  size      Float?

  owner_id String

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  // Relations
  owner     User       @relation(fields: [owner_id], references: [id], onDelete: Cascade)
  images    Image[]
  favorites Favorite[]
  inquiries Inquiry[]

  @@map("properties")
}

model Image {
  id          String @id @default(uuid())
  url         String
  property_id String

  property Property @relation(fields: [property_id], references: [id], onDelete: Cascade)

  @@map("images")
}

model Favorite {
  id          String   @id @default(uuid())
  user_id     String
  property_id String
  created_at  DateTime @default(now())

  user     User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  property Property @relation(fields: [property_id], references: [id], onDelete: Cascade)

  @@unique([user_id, property_id]) // prevent duplicate favorites
  @@map("favorites")
}

model Inquiry {
  id          String @id @default(uuid())
  property_id String
  user_id     String
  message     String

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  property Property @relation(fields: [property_id], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("inquiries")
}

enum Role {
  BUYER
  SELLER
  AGENT
  ADMIN
}

enum PropertyType {
  HOUSE
  FLAT
  LAND
  COMMERCIAL
}

enum PropertyStatus {
  ACTIVE
  SOLD
}
